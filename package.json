{
  "name": "blogsite",
  "version": "1.0.0",
  "description": "A blogging website made with node",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.19.0",
    "cookie-parser": "^1.4.5",
    "express": "^4.17.1",
    "hbs": "^4.1.1",
    "jsonwebtoken": "^8.5.1",
    "mongodb": "^3.6.4",
    "mongoose": "^5.11.16",
    "socket.io": "^4.1.2",
    "socket.io-client": "^4.1.2",
    "string-slice": "^0.1.0",
    "validator": "^13.5.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "env-cmd": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^2.0.7",
    "supertest": "^7.2.2"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "env-cmd -f ./config/dev.env nodemon src/index.js -e js,hbs",
    "test": "env-cmd -f ./config/test.env jest --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/fixtures/setup.js"
    ]
  },
