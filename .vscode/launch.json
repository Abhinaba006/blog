{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Blog App with Nodemon",
      "runtimeExecutable": "nodemon",
      "args": ["${workspaceFolder}/src/index.js"],
      "restart": true,
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/config/dev.env"
    }
  ]
}