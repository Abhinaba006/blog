{
  "info": {
    "name": "Blog Site API",
    "description": "Postman collection for the blog app routes. Use login first and allow cookies so authenticated routes work.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "Test User", "type": "text" },
                { "key": "email", "value": "test@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/user",
              "host": ["{{baseUrl}}"],
              "path": ["user"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "test@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/user/login",
              "host": ["{{baseUrl}}"],
              "path": ["user", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/user/logout",
              "host": ["{{baseUrl}}"],
              "path": ["user", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/user/me",
              "host": ["{{baseUrl}}"],
              "path": ["user", "me"]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"]
            }
          },
          "description": "Replace :id with the actual user ID from the users list. Requires auth cookie."
        }
      ]
    },
    {
      "name": "Blogs",
      "item": [
        {
          "name": "Get Published Blogs (Home)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          }
        },
        {
          "name": "Get Blog by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/blogs/:id",
              "host": ["{{baseUrl}}"],
              "path": ["blogs", ":id"]
            }
          },
          "description": "Replace :id with an actual blog post ID."
        },
        {
          "name": "Create Blog",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "title", "value": "My First Post", "type": "text" },
                { "key": "text", "value": "This is the body of my first blog post.", "type": "text" },
                { "key": "published", "value": "true", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/blogs",
              "host": ["{{baseUrl}}"],
              "path": ["blogs"]
            }
          }
        },
        {
          "name": "Edit Blog",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "title", "value": "Updated Title", "type": "text" },
                { "key": "text", "value": "Updated blog content.", "type": "text" },
                { "key": "published", "value": "true", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/editpost/:id",
              "host": ["{{baseUrl}}"],
              "path": ["editpost", ":id"]
            }
          },
          "description": "Replace :id with the actual blog post ID."
        },
        {
          "name": "Delete Blog",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/blogs/:id",
              "host": ["{{baseUrl}}"],
              "path": ["blogs", ":id"]
            }
          },
          "description": "Replace :id with the actual blog post ID."
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Post Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "text", "value": "Nice post!", "type": "text" },
                { "key": "postID", "value": "{{blogId}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/blogs/comment/:id",
              "host": ["{{baseUrl}}"],
              "path": ["blogs", "comment", ":id"]
            }
          },
          "description": "Replace :id with the blog ID. Also provide postID in the body."
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Chat Page",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            }
          },
          "description": "This route returns the chat page. Socket.IO communication is tested through the browser, not Postman."
        }
      ]
    }
  ]
}

