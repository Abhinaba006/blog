{{>header}}

<body>
    {{>nav}}
    <div class="page-shell">
        <div class="page-card page-form">
            <div class="page-header">
                <h1>Edit Post</h1>
            </div>
            <form id="edit-post-form" class="auth-form" data-blog-id="{{blog._id}}">
                <div class="form-group">
                    <label for="title">Title</label>
                    <input type="text" name="title" id="title" class="form-control" placeholder="Title of header" value="{{blog.title}}" required>
                </div>
                <div class="form-group">
                    <label for="text">Content</label>
                    <textarea name="text" id="text" class="form-control" placeholder="Enter your story" required>{{blog.text}}</textarea>
                </div>
                <div class="form-group" style="position: relative;">
                    <label for="tags">Tags</label>
                    <input type="text" name="tags" id="tags" class="form-control" placeholder="Enter tags separated by commas" value="{{#each blog.tags}}{{this.name}}{{#unless @last}}, {{/unless}}{{/each}}">
                </div>
                <script>document.addEventListener('DOMContentLoaded', () => { initializeTagAutocomplete('#tags') })</script>
                <div class="form-group">
                    <label for="flexCheckDefault">
                        <input class="form-check-input" type="checkbox" value="true" id="flexCheckDefault" name="published" {{#if blog.published}}checked{{/if}}>
                        Publish to public
                    </label>
                </div>
                <button type="submit" class="btn btn-primary">Update post</button>
            </form>
        </div>
    </div>
    <script src="/js/editPost.js"></script>
</body>