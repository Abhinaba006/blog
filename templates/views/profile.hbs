{{>header}}
<script src="/js/index.js"></script>
<body>
    {{>nav}}
    <div class="page-shell">
        <div class="page-card">
            <div class="page-header">
                <div>
                    <h1>{{name}}</h1>
                    <small class="text-muted">{{email}}</small>
                </div>
            </div>
            {{#each blogs}}
            <div class="card">
                <a href="/blogs/{{this._id}}"><h2>{{this.title}}</h2></a>
                <p>{{this.text}}</p>
                {{#if isOwner}}
                <div class="card-actions">
                    <button id="delete-blog" onclick="deleteBlog('{{this._id}}')" class="btn btn-secondary">Delete</button>
                    <a href="/editpost/{{this._id}}" class="btn btn-secondary">Edit</a>
                </div>
                {{/if}}
                <small>Created at {{{trimDate this.createdAt}}}</small>
            </div>
            {{/each}}

            {{#if blogs_n}}
            <div class="page-header">
                <h2>Not published posts</h2>
            </div>
            {{#each blogs_n}}
            <div class="card">
                <h2>{{this.title}}</h2>
                <p>{{this.text}}</p>
                <div class="card-actions">
                    <button id="delete-blog" onclick="deleteBlog('{{this._id}}')" class="btn btn-secondary">Delete</button>
                    <a href="/editpost/{{this._id}}" class="btn btn-secondary">Edit</a>
                </div>
                <small>Created at {{{trimDate this.createdAt}}}</small>
            </div>
            {{/each}}
            {{/if}}
        </div>
    </div>
</body>