{{>header}}
{{>nav}}

<script src="/js/index.js"></script>
<script src="/js/comment.js"></script>

<body>
    <div class="page-shell">
        <div class="page-card">
            <div class="page-header">
                <h1>{{blog.title}}</h1>
                <div class="page-actions">
                    {{#ifEquals userID blog.owner }}
                    <button id="delete-blog" onclick="deleteBlog('{{blog._id}}')"
                        class="btn btn-secondary">Delete</button>
                    <a href="/editpost/{{blog._id}}" class="btn btn-secondary">Edit</a>
                    {{/ifEquals}}
                </div>
            </div>
            <div class="card">
                <p>{{blog.text}}</p>
                <small>Created at {{{trimDate blog.createdAt}}}</small>
                <small>Written by {{blog.author}}</small>
                <div class="tags-container">
                    <small>
                        Tags:
                        {{#each blog.tagsName}}
                        <span class="badge-info">{{this}}</span>{{#unless @last}},{{/unless}}
                        {{/each}}
                    </small>
                </div>
            </div>
            <div class="page-header">
                <h2>Comments</h2>
            </div>

            <form id="comment-form" class="comment-form">
                <input type="text" name="text" id="comment-text" class="form-control" placeholder="Enter your comment">
                <input type="hidden" name="postID" id="comment-post-id" value="{{blog._id}}">
                <button type="submit" class="btn btn-primary">Post Comment</button>
            </form>
            {{#each comments}}
            <div class="message-card" data-comment-id="{{this._id}}">
                <p class="comment-text">{{this.text}}</p>
                <small>by {{this.author}}</small>
                <small>Created at {{{trimDate this.createdAt}}}</small>
                {{#ifEquals ../userID this.owner }}
                <div class="card-actions">
                    <button type="button" class="btn btn-secondary comment-delete"
                        data-comment-id="{{this._id}}">Delete</button>
                    <button type="button" class="btn btn-secondary comment-edit"
                        data-comment-id="{{this._id}}">Edit</button>
                </div>
                {{/ifEquals}}
            </div>
            {{/each}}
        </div>
    </div>
</body>