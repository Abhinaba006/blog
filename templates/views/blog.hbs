{{>header}}
{{>nav}}

<script src="/js/index.js"></script>
<script src="/js/comment.js"></script>

<body>
    <div class="page-shell">
        <div class="page-card">
            <div class="page-header">
                <h1>{{blog.title}}</h1>
                <div class="page-actions">
                    {{#ifEquals userID blog.owner }}
                    <button id="delete-blog" onclick="deleteBlog('{{blog._id}}')" class="btn btn-secondary">Delete</button>
                    <a href="/editpost/{{blog._id}}" class="btn btn-secondary">Edit</a>
                    {{/ifEquals}}
                </div>
            </div>
            <div class="card">
                <p>{{blog.text}}</p>
                <small>Created at {{{trimDate blog.createdAt}}}</small>
                <small>Written by {{blog.author}}</small>
            </div>
            <div class="page-header">
                <h2>Comments</h2>
            </div>
            <form action="/blogs/comment/:id" method="post" class="comment-form">
                <input type="text" name="text" class="form-control" placeholder="Enter your comment">
                <input type="hidden" name="postID" value={{blog._id}}>
                <button type="submit" class="btn btn-primary">Post Comment</button>
            </form>
            {{#each comments}}
            <div class="message-card">
                <p>{{this.text}}</p>
                <small>by {{this.author}}</small>
                <small>Created at {{{trimDate this.createdAt}}}</small>
                {{#ifEquals ../userID this.owner }}
                <div class="card-actions">
                    <button id="delete-blog" onclick="" class="btn btn-secondary">Delete</button>
                    <a href="#" class="btn btn-secondary">Edit</a>
                </div>
                {{/ifEquals}}
            </div>
            {{/each}}
        </div>
    </div>
</body>