{{>header}}

<body>
    {{>nav}}
    <div class="page-shell">
        <div class="page-card">
            <div class="page-header">
                <h1>All Posts</h1>
                <div class="page-actions">
                    <a href="/post" class="btn btn-primary">New Post</a>
                </div>
            </div>
            {{#each blogs}}
            <div class="card">
                <h2><a href="blogs/{{this._id}}" class="text-dark">{{this.title}}</a></h2>
                <p>{{this.text}}</p>
                <div class="card-actions">
                    {{#ifEquals ../userid this.owner }}
                    <button id="delete-blog" onclick="deleteBlog('{{this._id}}')" class="btn btn-secondary">Delete</button>
                    <a href="/editpost/{{this._id}}" class="btn btn-secondary">Edit</a>
                    {{/ifEquals}}
                </div>
                <small>Created at {{{trimDate this.createdAt}}}</small>
                <small>Written by {{this.author}}</small>
                <small>Tags: {{#each this.tags}}<span class="badge badge-info">{{this.name}}</span>{{/each}}</small>
            </div>
            {{/each}}
        </div>
    </div>
    <script src="/js/index.js"></script>
</body>