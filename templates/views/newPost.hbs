{{>header}}

<body>
    {{>nav}}
    <div class="page-shell">
        <div class="page-card page-form">
            <div class="page-header">
                <h1>New Post</h1>
            </div>
            <form action="/blogs" method="post" id="new-post-form" class="auth-form">
                <div class="form-group">
                    <label for="post-title">Title</label>
                    <input type="text" name="title" id="post-title" class="form-control" placeholder="Title of header" required>
                </div>
                <div class="form-group">
                    <label for="post-text">Content</label>
                    <textarea name="text" id="post-text" class="form-control" placeholder="Enter your story" required></textarea>
                </div>
                <div class="form-group" id="publish-wrapper" style="display: none;">
                    <label for="publish-checkbox">
                        <input type="checkbox" value="true" id="publish-checkbox" name="published">
                        Publish to public
                    </label>
                </div>
                <button type="submit" id="post-submit" class="btn btn-primary" disabled>Post</button>
            </form>
        </div>
    </div>
    <script src="/js/newPost.js"></script>
</body>